# -----------------------------------------------------------------------------
# Secrets / local config — NEVER commit
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Virtual envs
venv/
.venv/
env/
ENV/
backend/venv/

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
dist/
build/
.vite/
.next/
.cache/
*.log

# -----------------------------------------------------------------------------
# Editors / OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# -----------------------------------------------------------------------------
# Runtime / data we don't want in VCS
# -----------------------------------------------------------------------------
data/memory/*.json
!data/memory/.gitkeep
